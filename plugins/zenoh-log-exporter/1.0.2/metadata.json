{
      "id": "zenoh-log-exporter",
      "name": "Zenoh Log Streamer",
      "version": "1.0.2",
      "author": "DevOps Tools Inc.",
      "description": "Ermöglicht Live-Log-Streaming via Zenoh On-Demand.",
      "priority": 80,
      "status": "stable",
      "load_strategy": "lazy",
      "scope": {
        "type": "template", 
        "target": "welding_cell"
      },
      "compatible_with": ["v2_dashboard", "gateway_node"],
      
      "permissions": {
        "zenoh_scopes": ["myproject/logs/**"],
        "network": false,
        "storage": "read-only"
      },

      "entry_points": {
        "backend": {
          "type": "wasm",
          "file": "plugins/zenoh-log-exporter/1.0.2/logic.wasm",
          "handler": "init_stream",
          "runtime_limits": {
            "memory_mb": 64,
            "cpu_shares": 0.2
          }
        },
        "frontend": {
          "type": "module",
          "file": "plugins/zenoh-log-exporter/1.0.2/ui/index.js",
          "css": ["plugins/zenoh-log-exporter/1.0.2/ui/style.css"],
          "slots": [
            {
              "id": "sidebar-bottom",
              "component": "LogStatusIcon",
              "priority": 10
            },
            {
              "id": "app_drawer_right",
              "component": "LiveLogPanel",
              "title": "Zenoh Live Logs"
            }
          ]
        }
      },

      "help_data": {
        "wiki_path": "plugins/zenoh-log-exporter/1.0.2/docs/readme.md",
        "search_keywords": ["logs", "debug", "zenoh", "stream"]
      },

      "hash": "aef036f639d3486a985b65ee25df8fec",
      "checksum": "eebc2ba84282c5bca22258e95f0bceceb0"
    }